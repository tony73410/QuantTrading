# Alpaca credentials. The current implementation uses these only for Market Data.
# A future Paper execution module may use approved Alpaca Paper credentials, but
# key presence alone never enables order submission or Live Trading.
# Never place real values in this file.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# No Fidelity username, password, 2FA value, or API key is accepted by this project.
# Default execution target: Alpaca Paper. Execution is not implemented.
# Automatic order submission: OFF. Live Trading: OFF. Manual confirmation: REQUIRED.

# Optional local cache behavior. Defaults shown; values must be positive integers.
MARKET_HISTORY_CACHE_MAX_AGE_HOURS=24
MARKET_HISTORY_OVERLAP_BARS=5
MARKET_HISTORY_AUTO_REFRESH_MINUTES=5

# Optional diagnostics. Debug changes log detail only; it never enables orders.
QUANT_TRADE_DEBUG=false
QUANT_TRADE_LOG_LEVEL=INFO
